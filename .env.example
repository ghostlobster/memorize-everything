# =============================================================================
# memorize-everything — environment variables
# Copy this file to .env.local and fill in values. Never commit real secrets.
# =============================================================================

# -- Database (Neon Postgres) -------------------------------------------------
# Pooled connection used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct (unpooled) connection used by drizzle-kit for migrations.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"
# OPTIONAL: read-only preview-branch URL consumed by the Claude
# Code Postgres MCP server (.mcp.json). Must point at the Neon
# **preview** branch — never production. The MCP server fails to
# start if this is unset, which is the safety gate; do not paste
# DATABASE_URL here as a fallback.
DATABASE_URL_PREVIEW="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB-preview?sslmode=require"

# -- Auth.js (NextAuth v5) ----------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# GitHub OAuth app (https://github.com/settings/developers)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
# Google OAuth — optional; omit to disable Google sign-in
# (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Resend magic-link — optional; omit to disable email sign-in
# (https://resend.com/api-keys)
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM="noreply@memorize-everything.app"
# In production set to your canonical URL (e.g. https://memorize.example.com)
# Auth.js auto-detects on Vercel; uncomment for custom domains.
# AUTH_URL=""

# -- LLM providers ------------------------------------------------------------
# Default provider used for new decks. One of: google | anthropic | openai
DEFAULT_MODEL_PROVIDER="google"

# Gemini (default). Get one: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# Optional fallbacks — leave blank to disable the provider.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
